# ==========================================
# Python Official Environment
# ==========================================
# Virtual environments
venv/
.venv/
env/
bin/
include/
lib/
share/

# Python Cache & Bytecode
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
dist/
build/
eggs/
*.egg-info/
*.egg

# ==========================================
# Data & Large Files
# ==========================================

# Ignore everything in data
data/*

# Allow folders inside data
!data/**/

# Allow gitkeep files
!**/.gitkeep

# ==========================================
# Global security for data extensions
# ==========================================
*.csv
*.json
*.sql
*.sqlite3
*.parquet

# ==========================================
# Logs & Execution Trace
# ==========================================
*.log
govscape_pipeline.log
logs/

# ==========================================
# Operating System Files
# ==========================================
# macOS (The "DS_Store" you mentioned)
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# ==========================================
# Editor / IDE (VS Code, PyCharm)
# ==========================================
.vscode/
.idea/
*.swp
*.swo

# ==========================================
# Environment Secrets (CRITICAL)
# ==========================================
.env
.venv
